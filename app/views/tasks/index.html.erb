<div class="d-flex justify-content-between align-items-center mb-4">
  <h1 class="h3 fw-bold mb-0">
    <i class="bi bi-list-check me-2 text-primary"></i>タスク一覧
  </h1>
  <%= link_to new_task_path, class: "btn btn-primary" do %>
    <i class="bi bi-plus-circle me-1"></i>新しいタスク
  <% end %>
</div>

<!-- 統計カード -->
<div class="row g-3 mb-4">
  <div class="col-md-4">
    <div class="card border-0 shadow-sm text-center py-3">
      <div class="fs-2 fw-bold text-primary"><%= @total_count %></div>
      <div class="text-muted small">全タスク</div>
    </div>
  </div>
  <div class="col-md-4">
    <div class="card border-0 shadow-sm text-center py-3">
      <div class="fs-2 fw-bold text-success"><%= @completed_count %></div>
      <div class="text-muted small">完了済み</div>
    </div>
  </div>
  <div class="col-md-4">
    <div class="card border-0 shadow-sm text-center py-3">
      <div class="fs-2 fw-bold text-warning"><%= @pending_count %></div>
      <div class="text-muted small">未完了</div>
    </div>
  </div>
</div>

<!-- フィルター -->
<div class="card border-0 shadow-sm mb-4">
  <div class="card-body py-2">
    <div class="d-flex gap-2 flex-wrap align-items-center">
      <span class="text-muted small me-1">フィルター:</span>
      <%= link_to tasks_path, class: "btn btn-sm #{params[:completed].blank? && params[:priority].blank? ? 'btn-primary' : 'btn-outline-secondary'}" do %>
        すべて
      <% end %>
      <%= link_to tasks_path(completed: false), class: "btn btn-sm #{params[:completed] == 'false' ? 'btn-warning' : 'btn-outline-warning'}" do %>
        未完了
      <% end %>
      <%= link_to tasks_path(completed: true), class: "btn btn-sm #{params[:completed] == 'true' ? 'btn-success' : 'btn-outline-success'}" do %>
        完了済み
      <% end %>
      <div class="vr mx-1"></div>
      <% [["high", "danger", "高"], ["medium", "warning", "中"], ["low", "secondary", "低"]].each do |val, color, label| %>
        <%= link_to tasks_path(priority: val), class: "btn btn-sm #{params[:priority] == val ? "btn-#{color}" : "btn-outline-#{color}"}" do %>
          優先度: <%= label %>
        <% end %>
      <% end %>
    </div>
  </div>
</div>

<!-- タスクリスト -->
<% if @tasks.empty? %>
  <div class="card border-0 shadow-sm">
    <div class="card-body text-center py-5">
      <i class="bi bi-inbox display-4 text-muted"></i>
      <p class="mt-3 text-muted">タスクがありません。「新しいタスク」から追加してください。</p>
    </div>
  </div>
<% else %>
  <div class="d-flex flex-column gap-3">
    <% @tasks.each do |task| %>
      <%= render "task", task: task %>
    <% end %>
  </div>
  <div class="mt-4 d-flex justify-content-center">
    <%= paginate @tasks %>
  </div>
<% end %>
