<div id="task_<%= task.id %>" class="card border-0 shadow-sm <%= task.completed? ? 'opacity-75' : '' %>">
  <div class="card-body">
    <div class="d-flex justify-content-between align-items-start gap-3">
      <!-- 完了チェックボタン -->
      <div class="flex-shrink-0 pt-1">
        <%= button_to toggle_task_path(task), method: :patch,
            class: "btn btn-sm #{task.completed? ? 'btn-success' : 'btn-outline-secondary'} rounded-circle p-1",
            style: "width: 32px; height: 32px;",
            title: task.completed? ? "未完了に戻す" : "完了にする" do %>
          <i class="bi <%= task.completed? ? 'bi-check-lg' : 'bi-circle' %>"></i>
        <% end %>
      </div>

      <!-- タスク内容 -->
      <div class="flex-grow-1">
        <div class="d-flex flex-wrap gap-2 align-items-center mb-1">
          <h5 class="mb-0 <%= task.completed? ? 'text-decoration-line-through text-muted' : '' %>">
            <%= task.title %>
          </h5>
          <!-- 優先度バッジ -->
          <% priority_config = { "high" => ["danger", "高"], "medium" => ["warning", "中"], "low" => ["secondary", "低"] } %>
          <% color, label = priority_config[task.priority] %>
          <span class="badge bg-<%= color %>">優先度: <%= label %></span>
          <!-- 締切日 -->
          <% if task.due_date %>
            <span class="badge <%= task.due_date < Date.today && !task.completed? ? 'bg-danger' : 'bg-light text-dark border' %>">
              <i class="bi bi-calendar me-1"></i><%= task.due_date.strftime("%Y/%m/%d") %>
            </span>
          <% end %>
        </div>

        <!-- 説明 -->
        <% if task.description.present? %>
          <p class="text-muted small mb-2"><%= task.description %></p>
        <% end %>

        <!-- AI 提案 -->
        <% if task.ai_suggestion.present? %>
          <details class="mt-2">
            <summary class="btn btn-sm btn-outline-primary py-0 px-2" style="list-style: none; cursor: pointer; display: inline-flex; align-items: center;">
              <i class="bi bi-robot me-1"></i>AI 提案
            </summary>
            <div class="bg-light rounded p-2 mt-2 border-start border-primary border-3">
              <p class="mb-0 small text-secondary" style="white-space: pre-line;"><%= task.ai_suggestion %></p>
            </div>
          </details>
        <% end %>
      </div>

      <!-- 操作ボタン -->
      <div class="flex-shrink-0 d-flex gap-1">
        <%= link_to edit_task_path(task), class: "btn btn-sm btn-outline-primary", title: "編集" do %>
          <i class="bi bi-pencil"></i>
        <% end %>
        <%= button_to task_path(task), method: :delete,
            class: "btn btn-sm btn-outline-danger",
            title: "削除",
            data: { turbo_confirm: "「#{h(task.title)}」を削除しますか？" } do %>
          <i class="bi bi-trash"></i>
        <% end %>
      </div>
    </div>
  </div>
</div>
